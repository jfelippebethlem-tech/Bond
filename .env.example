# Authentication
AUTH_SECRET=your-super-secret-key-here-change-this
ADMIN_PASSWORD=admin123

# Deputy Info
DEPUTY_NAME="Dep. João Silva"
DEPUTY_PARTY="PT"
DEPUTY_STATE="SP"

# AI Principal (Google Gemini - GRATUITO em aistudio.google.com)
# 1.500 req/dia grátis, sem cartão de crédito
GEMINI_API_KEY=your-gemini-api-key

# Hermes Agent (OpenRouter - GRATUITO em openrouter.ai)
# Usa Hermes 3 405B (NousResearch) — melhor modelo para agentes
# Fallback automático para Gemini se não configurado
OPENROUTER_API_KEY=your-openrouter-api-key

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Bond Agent — Redes Sociais do Deputado
# Twitter/X API v2 (free at developer.twitter.com)
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_USERNAME=seu_usuario_twitter

# Facebook Page (Graph API - free at developers.facebook.com)
# Precisa de uma Página do Facebook (não perfil pessoal)
FACEBOOK_PAGE_TOKEN=your-facebook-page-access-token

# Instagram é automaticamente conectado via FACEBOOK_PAGE_TOKEN
# (precisa de conta Business/Creator vinculada à Página)

# WhatsApp — 100% GRATUITO via Baileys (WhatsApp Web)
# NÃO precisa de chave de API nem cartão. A conexão é por QR Code:
#   1. Rode: npm run whatsapp
#   2. Abra a página /whatsapp e escaneie o QR com o celular
#   3. A sessão fica salva em ./.whatsapp-auth (NÃO commitar)

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Captura de curtidores/stories (DESKTOP — IP residencial; NUNCA na VM) ────────
IG_CAPTURE_LOCAL=true            # trava de segurança: só roda com isto = true
IG_PROFILE_DIR=C:\jfn\ig-profile # perfil de navegador dedicado (você loga 1x)
LIKERS_OUT_DIR=C:\jfn\bond\likers-sync  # pasta Syncthing -> VM
IG_SINCE=2026-01-01              # janela: só posts a partir desta data
IG_NUM_POSTS=20                  # posts por execução (run)
IG_RECENT=10                     # nº de posts mais recentes SEMPRE re-capturados (curtidas novas)
IG_MODE=manha                    # manha (10 recentes + 10 backfill) | noite (20 backfill)
IG_STORIES=true                  # captura quem resharou nos stories (EXPERIMENTAL — validar)
IG_MAX_FALHAS=3                  # aborta após N posts seguidos sem curtidores (anti-bloqueio)
# ritmo humano (anti-ban) — ms:
IG_PAUSA_MIN=6000
IG_PAUSA_MAX=20000
IG_DESCANSO_MIN=45000
IG_DESCANSO_MAX=150000
# IG_TARGET_USER=1985223190      # (só p/ 2ª conta lendo a business; vazio = modo OWNER, pega tudo)
