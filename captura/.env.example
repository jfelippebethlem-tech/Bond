# ===== CAPTURA HUMANA DE CURTIDORES — parâmetros (desktop, dirigido pelo Hermes) =====
# Copie para captura/.env (ou exporte no ambiente do Hermes). NUNCA versionar o .env real.

# --- MOTOR (teste os 3 e compare qual passa mais limpo pela Meta) ---
IG_ENGINE=cdp                 # cdp (recomendado) | playwright | nodriver(=python capture_nodriver.py)

# --- ALVO ---
IG_TARGET_USER=               # perfil PÚBLICO a capturar (ex.: um teste antes do seu). Sem @.
IG_PERFIL=depjorgefelippeneto # usado se IG_TARGET_USER vazio

# --- CHROME REAL via CDP (motores cdp e playwright-conectado) ---
# Abra o Chrome REAL logado assim ANTES de rodar (perfil dedicado, IP residencial):
#   chrome.exe --remote-debugging-port=9222 --user-data-dir="C:\jfn\ig-profile"
IG_CDP_URL=http://127.0.0.1:9222
IG_CHROME_CHANNEL=chrome      # se o playwright lançar o Chrome real (sem CDP_URL)
IG_PROFILE_DIR=C:\jfn\ig-profile   # perfil de navegador dedicado (sessão logada salva aqui)

# --- TEMPOS (regra do dono: REALMENTE aleatório, 15–200s por post) ---
IG_TEMPO_MIN=15
IG_TEMPO_MAX=200
IG_MAX_SHOTS=30               # teto de prints por post (posts gigantes não explodem o disco)

# --- VOLUME (anti-ban: pouco e devagar) ---
IG_NUM_POSTS=12               # posts por execução
IG_RECENT=6                   # recentes sempre re-capturados
IG_MAX_FALHAS=3               # aborta se o modal não abrir em N posts seguidos (sinal de bloqueio)
IG_FORCE=false                # true ignora o ledger e recaptura tudo

# --- SAÍDA (Syncthing leva pra VM) ---
LIKERS_SHOTS_DIR=C:\jfn\bond\captura\shots    # prints -> a VM lê e depura
LIKERS_OUT_DIR=C:\jfn\bond\likers-sync        # status/ledger (mesma pasta sincronizada de hoje)
IG_VP_W=1366
IG_VP_H=768

# ===== DEPURAÇÃO (parse_likers.py) — roda na VM, NÃO no desktop =====
GEMINI_PROVIDER=apikey        # apikey (free tier, headless) | oauth (assinatura Gemini Plus) | openrouter
GEMINI_MODEL=                 # vazio = gemini-2.5-flash (apikey) ou gemini-2.5-pro (oauth)
# GEMINI_API_KEY=...          # já está no polimonitor/.env
# GEMINI_OAUTH_TOKEN=...      # Bearer da assinatura Plus (ver runbook, Passo OAuth)
# GEMINI_OAUTH_TOKEN_FILE=/home/ubuntu/.hermes/gemini_oauth_token
# GEMINI_ENDPOINT=...         # override do endpoint (Code Assist), se necessário
