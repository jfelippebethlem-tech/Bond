generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pessoa {
  id           String   @id @default(cuid())
  nome         String
  tipo         String   // "funcionario" | "apoiador" | "coordenador" | "contato"
  cargo        String?
  email        String?
  telefone     String?
  twitter      String?
  instagram    String?
  facebook     String?
  telegramUser String?
  ativo        Boolean  @default(true)
  observacoes  String?
  // ── Métricas avançadas / gamificação ──
  seguidores   Int      @default(0)  // nº de seguidores do apoiador (p/ Influencer Score)
  streak       Int      @default(0)  // posts consecutivos em que engajou (sequência)
  npsUltimo    Int?                  // última nota pNPS (0-10)
  npsData      DateTime?             // data da última resposta pNPS
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  posts        Post[]
  demandas     Demanda[]
  bondFas      BondFa[]
  npsRespostas NpsResposta[]
}

model Post {
  id         String   @id @default(cuid())
  plataforma String
  conteudo   String
  url        String?
  likes      Int      @default(0)
  shares     Int      @default(0)
  sentimento String?
  pessoaId   String?
  pessoa     Pessoa?  @relation(fields: [pessoaId], references: [id])
  palavra    String?
  criadoEm  DateTime @default(now())
}

model Demanda {
  id           String   @id @default(cuid())
  titulo       String
  descricao    String
  status       String   @default("aberta")  // "aberta" | "andamento" | "resolvida"
  prioridade   String   @default("media")
  origem       String?  // "telegram" | "painel" | "whatsapp" | ...
  responsavel  String?  // quem responde pela demanda (nome/handle)
  prazo        DateTime?            // prazo-alvo opcional
  pessoaId     String?
  pessoa       Pessoa?  @relation(fields: [pessoaId], references: [id])
  resposta     String?
  alertadoEm   DateTime?            // última vez que o alerta diário (vermelho) disparou
  resolvidoEm  DateTime?            // quando virou "resolvida"
  passos       DemandaPasso[]
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([status, criadoEm])
}

// Passos de execução de uma demanda — colaborativo (cada um com responsável e check).
model DemandaPasso {
  id          String   @id @default(cuid())
  demandaId   String
  demanda     Demanda  @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  descricao   String
  feito       Boolean  @default(false)
  responsavel String?
  ordem       Int      @default(0)
  criadoEm    DateTime @default(now())
  feitoEm     DateTime?

  @@index([demandaId, ordem])
}

model Atividade {
  id        String   @id @default(cuid())
  tipo      String
  titulo    String
  descricao String?
  data      DateTime
  resultado String?
  criadoEm DateTime @default(now())
}

model PalavraChave {
  id      String  @id @default(cuid())
  palavra String  @unique
  ativa   Boolean @default(true)
}

model TelegramMensagem {
  id         String   @id @default(cuid())
  chatId     String
  userId     String?
  username   String?
  nome       String?
  mensagem   String
  respondida Boolean  @default(false)
  resposta   String?
  criadoEm  DateTime @default(now())
}

model Configuracao {
  id    String @id @default(cuid())
  chave String @unique
  valor String
}

model HermesMemoria {
  id           String   @id @default(cuid())
  tipo         String   // "padrao" | "preferencia" | "cidadao" | "assunto" | "estatistica" | "contexto"
  chave        String
  conteudo     String
  relevancia   Float    @default(1.0)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([tipo, chave])
}

model HermesJob {
  id           String    @id @default(cuid())
  tipo         String    // "analise_demanda" | "analise_post" | "analise_telegram" | "resumo_diario" | "chat"
  payload      String    // JSON
  status       String    @default("pendente") // "pendente" | "processando" | "concluido" | "erro"
  resultado    String?
  erro         String?
  criadoEm    DateTime  @default(now())
  processadoEm DateTime?
}

model HermesInsight {
  id         String   @id @default(cuid())
  titulo     String
  descricao  String
  tipo       String   @default("sugestao") // "alerta" | "sugestao" | "resumo" | "padrao" | "acao"
  prioridade String   @default("media")   // "alta" | "media" | "baixa"
  lido       Boolean  @default(false)
  criadoEm  DateTime @default(now())
}

model BondPerfil {
  id           String    @id @default(cuid())
  plataforma   String    // "facebook" | "instagram" | "twitter"
  handle       String
  nomeCompleto String?
  seguidores   Int       @default(0)
  seguindo     Int       @default(0)
  totalPosts   Int       @default(0)
  bio          String?
  fotoUrl      String?
  ativo        Boolean   @default(true)
  categoria    String    @default("proprio") // "proprio" | "adversario"
  ultimaSync   DateTime?
  criadoEm    DateTime  @default(now())
  postagens    BondPost[]

  @@unique([plataforma, handle])
}

model BondPost {
  id             String   @id @default(cuid())
  plataforma     String
  postId         String
  conteudo       String
  tipo           String   @default("texto") // "texto"|"foto"|"video"|"reel"|"story"|"link"
  url            String?
  imagemUrl      String?
  likes          Int      @default(0)
  comentarios    Int      @default(0)
  compartilhos   Int      @default(0)
  saves          Int      @default(0)
  alcance        Int      @default(0)
  impressoes     Int      @default(0)
  engajamento    Float    @default(0)
  publicadoEm   DateTime
  sincronizadoEm DateTime @default(now())
  fasJson        String?  // JSON array of {id,nome,username} who engaged
  notificado     Boolean  @default(false) // já avisou apoiadores via WhatsApp?
  perfilId       String
  perfil         BondPerfil @relation(fields: [perfilId], references: [id])

  @@unique([plataforma, postId])
}

model BondFa {
  id           String   @id @default(cuid())
  plataforma   String
  externalId   String
  nome         String?
  username     String?
  fotoUrl      String?
  totalLikes   Int      @default(0)
  totalComents Int      @default(0)
  totalShares  Int      @default(0)
  ultimaInter  DateTime?
  pessoaId     String?
  pessoa       Pessoa?  @relation(fields: [pessoaId], references: [id])
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([plataforma, externalId])
  @@index([plataforma, totalLikes])
  @@index([username])
}

model BondInteracao {
  id         String   @id @default(cuid())
  plataforma String
  externalId String
  tipo       String   // "like" | "comment" | "share"
  postId     String
  publicadoEm DateTime?  // data REAL da interação quando a API fornece (ex.: comentário); null = usa criadoEm
  criadoEm  DateTime @default(now())   // hora da INGESTÃO/sync

  @@unique([plataforma, externalId, tipo, postId])
  @@index([plataforma, tipo])
  @@index([publicadoEm])
}

model BondComentario {
  id            String   @id @default(cuid())
  plataforma    String
  postId        String
  comentarioId  String
  autor         String?
  autorId       String?
  texto         String
  respondido    Boolean  @default(false)
  sugestaoIA    String?
  respostaFinal String?
  publicadoEm   DateTime?  // data REAL do comentário (created_time FB / timestamp IG); null = legado → usa criadoEm
  criadoEm     DateTime @default(now())   // hora da INGESTÃO/sync (NÃO é a data real do comentário)

  @@unique([plataforma, comentarioId])
  @@index([plataforma, autor])
  @@index([publicadoEm])
}

model BondEstilo {
  id         String   @id @default(cuid())
  comentario String
  resposta   String
  plataforma String?
  criadoEm  DateTime @default(now())
}

model BondInsight {
  id         String   @id @default(cuid())
  titulo     String
  descricao  String
  tipo       String   @default("sugestao") // "performance"|"audiencia"|"horario"|"conteudo"|"sugestao"|"alerta"
  plataforma String?  // null = cross-platform
  dados      String?  // JSON with extra data
  lido       Boolean  @default(false)
  criadoEm  DateTime @default(now())
}

model BondRascunho {
  id           String    @id @default(cuid())
  titulo       String?
  texto        String
  plataformas  String    @default("todas") // comma-separated or "todas"
  tipo         String    @default("post")
  hashtags     String?
  status       String    @default("rascunho") // "rascunho"|"aprovado"|"publicado"
  agendadoPara DateTime?
  criadoEm    DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
}

// ── Fila de mensagens WhatsApp (enviadas pelo whatsapp-worker via Baileys, grátis) ──
model WhatsappFila {
  id           String    @id @default(cuid())
  telefone     String    // número normalizado, ex: 5521999998888
  mensagem     String
  tipo         String    @default("notificacao") // "notificacao"|"cobranca"|"nps"|"conquista"|"broadcast"|"alerta"
  status       String    @default("pendente")    // "pendente"|"enviado"|"erro"
  erro         String?
  pessoaId     String?   // apoiador destinatário, se houver
  referencia   String?   // ex: postId relacionado
  tentativas   Int       @default(0)
  agendadoPara DateTime?
  criadoEm    DateTime  @default(now())
  enviadoEm    DateTime?
}

// ── Respostas pNPS dos apoiadores (Net Promoter Score político) ──
model NpsResposta {
  id        String   @id @default(cuid())
  pessoaId  String
  pessoa    Pessoa   @relation(fields: [pessoaId], references: [id])
  nota      Int      // 0-10
  categoria String   // "promotor" (9-10) | "passivo" (7-8) | "detrator" (0-6)
  comentario String?
  criadoEm DateTime @default(now())
}

// ── Registro de ações executadas pelo Hermes/sistema (auditoria p/ IA fraca) ──
model AcaoLog {
  id        String   @id @default(cuid())
  acao      String   // nome da ação do catálogo
  origem    String   @default("hermes") // "hermes" | "humano" | "sistema"
  params    String?  // JSON dos parâmetros
  resultado String?  // resumo do resultado
  sucesso   Boolean  @default(true)
  erro      String?
  criadoEm DateTime @default(now())
}

// ── Análise de viralização por post (Analista de Redes) ──
// Uma linha por post analisado. Keyed pelo postId do IG (sem relação formal p/ não
// migrar BondPost). camada 'A' = sem read_insights (sinais fracos); 'B' = com insights.
model BondViralScore {
  id            String   @id @default(cuid())
  postId        String   @unique // BondPost.postId (id da mídia no IG)
  superficie    String   // "reel" | "carrossel" | "feed" | "foto" | "video" | "story"
  scoreTotal    Float    @default(0) // 0-100
  sinais        String?  // JSON: { ganchoNota, ritmoNota, sendsPerReach?, savesPerReach?, ... }
  diagnostico   String   // por que (não) viralizou — texto acionável
  ganchoNota    Int?     // 0-10 (do Gemini assistindo a mídia)
  temaEmAlta    Boolean  @default(false) // o tema casou com alguma tendência?
  temaCasado    String?  // termo de tendência que casou, se houver
  camada        String   @default("A") // "A" | "B"
  conteudoResumo String? // resumo do que o Gemini viu na mídia
  criadoEm      DateTime @default(now())

  @@index([criadoEm])
}

// ── Relatório de análise (semanal / mensal / por post) gerado pela IA ──
model BondRelatorio {
  id        String   @id @default(cuid())
  tipo      String   // "semana" | "mes" | "post"
  titulo    String
  periodo   String?  // ex "2026-06-16 a 2026-06-22" | "Junho/2026" | postId
  prosa     String   // o relatório em prosa (sumário, acertos, erros, conclusões)
  dados     String?  // JSON: estatísticas + lista de posts analisados
  criadoEm  DateTime @default(now())

  @@index([criadoEm])
}

// ── Snapshot de tendência externa (sensor grátis: Google Trends/News RSS) ──
model BondTendencia {
  id          String   @id @default(cuid())
  termo       String
  fonte       String   // "google_trends" | "google_news" | "youtube" | "x"
  geo         String   @default("BR") // "BR" | "BR-RJ"
  rankOuScore Float?   // posição/volume quando a fonte fornece
  contexto    String?  // manchete/descrição associada
  capturadoEm DateTime @default(now())

  @@index([capturadoEm])
}
