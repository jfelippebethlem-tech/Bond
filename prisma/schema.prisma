generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pessoa {
  id           String   @id @default(cuid())
  nome         String
  tipo         String   // "funcionario" | "apoiador" | "contato"
  cargo        String?
  email        String?
  telefone     String?
  twitter      String?
  instagram    String?
  facebook     String?
  telegramUser String?
  ativo        Boolean  @default(true)
  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  posts        Post[]
  demandas     Demanda[]
}

model Post {
  id         String   @id @default(cuid())
  plataforma String
  conteudo   String
  url        String?
  likes      Int      @default(0)
  shares     Int      @default(0)
  sentimento String?
  pessoaId   String?
  pessoa     Pessoa?  @relation(fields: [pessoaId], references: [id])
  palavra    String?
  criadoEm  DateTime @default(now())
}

model Demanda {
  id           String   @id @default(cuid())
  titulo       String
  descricao    String
  status       String   @default("aberta")
  prioridade   String   @default("media")
  origem       String?
  pessoaId     String?
  pessoa       Pessoa?  @relation(fields: [pessoaId], references: [id])
  resposta     String?
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Atividade {
  id        String   @id @default(cuid())
  tipo      String
  titulo    String
  descricao String?
  data      DateTime
  resultado String?
  criadoEm DateTime @default(now())
}

model PalavraChave {
  id      String  @id @default(cuid())
  palavra String  @unique
  ativa   Boolean @default(true)
}

model TelegramMensagem {
  id         String   @id @default(cuid())
  chatId     String
  userId     String?
  username   String?
  nome       String?
  mensagem   String
  respondida Boolean  @default(false)
  resposta   String?
  criadoEm  DateTime @default(now())
}

model Configuracao {
  id    String @id @default(cuid())
  chave String @unique
  valor String
}

model HermesMemoria {
  id           String   @id @default(cuid())
  tipo         String   // "padrao" | "preferencia" | "cidadao" | "assunto" | "estatistica" | "contexto"
  chave        String
  conteudo     String
  relevancia   Float    @default(1.0)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([tipo, chave])
}

model HermesJob {
  id           String    @id @default(cuid())
  tipo         String    // "analise_demanda" | "analise_post" | "analise_telegram" | "resumo_diario" | "chat"
  payload      String    // JSON
  status       String    @default("pendente") // "pendente" | "processando" | "concluido" | "erro"
  resultado    String?
  erro         String?
  criadoEm    DateTime  @default(now())
  processadoEm DateTime?
}

model HermesInsight {
  id         String   @id @default(cuid())
  titulo     String
  descricao  String
  tipo       String   @default("sugestao") // "alerta" | "sugestao" | "resumo" | "padrao" | "acao"
  prioridade String   @default("media")   // "alta" | "media" | "baixa"
  lido       Boolean  @default(false)
  criadoEm  DateTime @default(now())
}
